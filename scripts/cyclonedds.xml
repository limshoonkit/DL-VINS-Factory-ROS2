<?xml version="1.0" encoding="UTF-8"?>
<!-- CycloneDDS tuning for ROS2 large-message (camera image) transport. -->
<CycloneDDS xmlns="https://cdds.io/config">
  <Domain Id="any">
    <Internal>
      <SocketReceiveBufferSize min="1 MiB" max="64 MiB"/>
      <SocketSendBufferSize min="1 MiB" max="16 MiB"/>
    </Internal>
  </Domain>
</CycloneDDS>
