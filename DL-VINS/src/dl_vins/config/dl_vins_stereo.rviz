        - /Global Options1
        - /Grid1
        - /Margin Landmarks1
        - /PGO Landmarks1
      Splitter Ratio: 0.5
    Tree Height: 459
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
